# ============================================
# SERVER CONFIGURATION
# ============================================

# Host address (0.0.0.0 allows external connections, localhost for local only)
HOST=0.0.0.0

# Port number for the Strapi server
PORT=1337

# Node environment (development, staging, production)
NODE_ENV=development

# ============================================
# SECURITY SECRETS
# ============================================
# IMPORTANT: Generate new secrets for production!
# Use: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"

# Application keys (comma-separated, minimum 4 keys for key rotation)
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4

# Salt for API tokens
API_TOKEN_SALT=tobemodified

# Secret for admin JWT tokens
ADMIN_JWT_SECRET=tobemodified

# Salt for transfer tokens
TRANSFER_TOKEN_SALT=tobemodified

# Secret for user JWT tokens (authentication system)
JWT_SECRET=tobemodified

# Encryption key for sensitive data
ENCRYPTION_KEY=tobemodified

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database client (sqlite, postgres, mysql, mysql2)
DATABASE_CLIENT=mysql

# Database host
DATABASE_HOST=127.0.0.1

# Database port (3306 for MySQL, 5432 for PostgreSQL)
DATABASE_PORT=3306

# Database name
DATABASE_NAME=orders

# Database username
DATABASE_USERNAME=root

# Database password
DATABASE_PASSWORD=root

# Enable SSL for database connection (true/false)
DATABASE_SSL=false

# Database filename (only for SQLite)
DATABASE_FILENAME=

# ============================================
# AUTHENTICATION CONFIGURATION
# ============================================

# JWT token expiration time (in seconds or string like '24h', '7d')
JWT_EXPIRATION=24h

# Refresh token expiration time
REFRESH_TOKEN_EXPIRATION=7d

# Maximum login attempts before account lock
MAX_LOGIN_ATTEMPTS=5

# Account lock duration in minutes
ACCOUNT_LOCK_DURATION=15

# ============================================
# EMAIL CONFIGURATION (for password reset)
# ============================================

# Email provider (sendmail, sendgrid, mailgun, etc.)
EMAIL_PROVIDER=sendmail

# SMTP configuration (if using SMTP)
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your-email@example.com
EMAIL_SMTP_PASSWORD=your-smtp-password
EMAIL_SMTP_SECURE=false

# Default from email address
EMAIL_FROM=noreply@example.com
EMAIL_REPLY_TO=support@example.com

# SendGrid API Key (if using SendGrid)
SENDGRID_API_KEY=

# Mailgun configuration (if using Mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# RATE LIMITING
# ============================================

# Enable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# Maximum requests per time window
RATE_LIMIT_MAX_REQUESTS=100

# Time window in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# ============================================
# LOGGING & MONITORING
# ============================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable security audit logging (true/false)
SECURITY_AUDIT_ENABLED=true

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Frontend application URL (for password reset links, etc.)
FRONTEND_URL=http://localhost:3000

# ============================================
# OPTIONAL: THIRD-PARTY SERVICES
# ============================================

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Cloudinary (alternative for file uploads)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Redis (for session storage and caching)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Sentry (for error tracking)
SENTRY_DSN=

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Enable GraphQL playground in production (true/false)
GRAPHQL_PLAYGROUND=false

# Enable detailed error messages (true/false)
DETAILED_ERRORS=false
