{
    "kind": "collectionType",
    "collectionName": "products",
    "info": {
        "singularName": "product",
        "pluralName": "products",
        "displayName": "Product"
    },
    "options": {
        "draftAndPublish": false
    },
    "attributes": {
        "sku": {
            "type": "string",
            "required": true,
            "unique": true
        },
        "name": {
            "type": "string",
            "required": true
        },
        "price": {
            "type": "decimal",
            "required": true
        },
        "stock": {
            "type": "integer",
            "required": true,
            "default": 0
        },
        "is_active": {
            "type": "boolean",
            "default": true
        },
        "order_items": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::order-item.order-item",
            "mappedBy": "product"
        }
    }
}