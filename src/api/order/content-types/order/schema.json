{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "customer_name": {
      "type": "string",
      "required": true
    },
    "customer_phone": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "orderStatus": {
      "type": "enumeration",
      "required": true,
      "default": "en_preparation",
      "enum": [
        "en_preparation",
        "produit_non_disponible",
        "sortie_en_livraison",
        "probleme_commande",
        "livree",
        "reportee",
        "annulee"
      ]
    },
    "total_price": {
      "type": "decimal",
      "default": 0
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "order"
    }
  }
}
